{
  "manifest_version": 3,
  "name": "StealthRelay Companion",
  "version": "1.0.0",
  "description": "Zero-trust disposable email aliases, RAM EXIF metadata bleaching, and client-side encrypted transient shares.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon-48.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://*.stealthrelay.com/*"
  ]
}
